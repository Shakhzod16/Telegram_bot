# -------------------------------------------------------------
# Runtime mode
# -------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=

# -------------------------------------------------------------
# Telegram bot
# -------------------------------------------------------------
BOT_TOKEN=your_real_bot_token
WEB_APP_URL=https://your-public-webapp-url
BOT_MODE=polling
WEBHOOK_URL=
WEBHOOK_LISTEN=0.0.0.0
WEBHOOK_PORT=8443
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=

# Comma separated Telegram user IDs with admin access.
ADMIN_IDS=
ADMIN_CHAT_ID=0
ADMIN_API_KEY=change_me_admin_key

# -------------------------------------------------------------
# Backend / API
# -------------------------------------------------------------
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
API_BASE_URL=http://127.0.0.1:8000
FRONTEND_ORIGIN=http://127.0.0.1:8000
CORS_ORIGINS=http://127.0.0.1:8000
DATABASE_URL=sqlite+aiosqlite:///./backend.db
DATABASE_PATH=food_delivery.db

# -------------------------------------------------------------
# Click payment
# -------------------------------------------------------------
CLICK_SERVICE_ID=your_click_service_id
CLICK_MERCHANT_ID=your_click_merchant_id
CLICK_SECRET_KEY=your_click_secret_key
CLICK_PAYMENT_URL_TEMPLATE=https://my.click.uz/services/pay?service_id={provider}&merchant_id={order_id}&amount={amount}

# -------------------------------------------------------------
# Payme payment
# -------------------------------------------------------------
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_KEY=your_payme_key
PAYME_CHECKOUT_URL=https://checkout.paycom.uz
PAYME_MERCHANT_API_URL=https://checkout.paycom.uz/api
PAYME_PAYMENT_URL_TEMPLATE=https://checkout.paycom.uz/{provider}?id={order_id}&amount={amount}

# -------------------------------------------------------------
# Performance / security
# -------------------------------------------------------------
PRODUCTS_CACHE_TTL_SECONDS=60
WEBAPP_INIT_DATA_TTL_SECONDS=86400
