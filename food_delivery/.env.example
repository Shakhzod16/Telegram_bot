# Backend
SECRET_KEY=your-super-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/food_delivery

# Redis
REDIS_URL=redis://localhost:6379/0

# App settings
DEBUG=true
DEV_MODE=true
BACKEND_URL=http://localhost:8000
MIN_ORDER_AMOUNT=15000
DELIVERY_FEE=5000

# Admin
ADMIN_TELEGRAM_IDS=123456789
SUPERADMIN_TELEGRAM_IDS=111222333

# Kuryer guruhi
COURIER_GROUP_ID=-1001234567890

# Dev tunnel (optional): none | auto | cloudflared | localtunnel
DEV_TUNNEL_PROVIDER=auto
